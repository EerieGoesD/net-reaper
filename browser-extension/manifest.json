{
  "manifest_version": 3,
  "name": "Net Reaper",
  "description": "Send downloads to Net Reaper download manager",
  "version": "0.1.0",
  "permissions": ["downloads", "nativeMessaging"],
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icon-16.png",
    "48": "icon-48.png",
    "128": "icon-128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon-16.png",
      "48": "icon-48.png"
    }
  }
}
