{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-utils/schema.json",
  "productName": "Net Reaper",
  "version": "0.1.0",
  "identifier": "com.eerie.net-reaper",
  "build": {
    "frontendDist": "../src",
    "beforeBuildCommand": "cargo build --release --bin net-reaper-host && powershell -NoProfile -Command \"New-Item -ItemType Directory -Force -Path binaries | Out-Null; Copy-Item target/release/net-reaper-host.exe binaries/net-reaper-host-x86_64-pc-windows-msvc.exe -Force\""
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "Net Reaper",
        "width": 1000,
        "height": 640,
        "minWidth": 780,
        "minHeight": 480,
        "decorations": true,
        "titleBarStyle": "Overlay",
        "transparent": false,
        "center": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; connect-src 'self' https://* http://*; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src https://fonts.gstatic.com"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "appimage", "dmg"],
    "externalBin": ["binaries/net-reaper-host"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installMode": "perMachine"
      }
    },
    "macOS": {
      "minimumSystemVersion": "10.15"
    },
    "linux": {
      "appimage": {
        "bundleMediaFramework": false
      }
    }
  }
}
